        <name>Create Production Change</name>
        <onclick/>
        <order>100</order>
        <script><![CDATA[function onAction() {
    var chg = new GlideRecord('change_request');
    chg.initialize();
    chg.short_description = 'Production change for ' + current.number;
    chg.description = current.short_description;
    chg.assignment_group.setDisplayValue('Release and Change');
    chg.insert();
    
    // Link the change back to the CR
    current.production_change = chg.sys_id; // use your actual field name
    current.autoSysFields(false);
    current.update();
    
    action.setRedirectURL(chg);
}]]></script>
