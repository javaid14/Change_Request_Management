        <script><![CDATA[var gr = new GlideRecord('x_enno_change_re_0_change_requests');

gr.addQuery('active', true);
gr.query();

while (gr.next()) {
    var opened = gr.getValue('opened_at');
    if (opened) {
        var openedDate = new GlideDateTime(opened);
        var now = new GlideDateTime();
        var duration = GlideDateTime.subtract(openedDate, now);
        var days = Math.floor(duration.getDayPart());
        gr.aging = days;
        gr.autoSysFields(false);
        gr.update();
    }
}]]></script>
